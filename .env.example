# ═══════════════════════════════════════════════════════════
# 全流程科研论文写作系统 — 环境变量配置模板
# ═══════════════════════════════════════════════════════════
#
# 使用方法：
#   1. 复制此文件为 .env：
#      cp .env.example .env          (Linux/Mac)
#      copy .env.example .env        (Windows)
#
#   2. 编辑 .env，填入你的 API Key
#
#   3. 或用命令行配置向导：
#      python scripts/config_wizard.py
#
#   4. 或用 Claude Code 命令（在 Claude Code 中）：
#      /配置LLM
# ═══════════════════════════════════════════════════════════

# ─── LLM 后端选择 ───
# 可选值: anthropic | openai
LLM_BACKEND=anthropic

# ─── Anthropic API（推荐，兼容 DeepSeek API） ───
# 获取 API Key: https://platform.deepseek.com/api_keys
# 或使用 Anthropic 官方: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here
# API 端点（DeepSeek Anthropic 兼容端点 / Anthropic 官方端点）
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# 模型选择
ANTHROPIC_MODEL=deepseek-v4-pro

# ─── OpenAI 兼容 API（备选，DeepSeek OpenAI 格式 / 通义千问 等） ───
# 获取 API Key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ─── 补充：若使用 DeepSeek OpenAI 格式 ───
# LLM_BACKEND=openai
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ─── Zotero 集成（可选） ───
# ZOTERO_LIBRARY_ID=1234567
# ZOTERO_LIBRARY_TYPE=user
# ZOTERO_API_KEY=your-zotero-api-key
